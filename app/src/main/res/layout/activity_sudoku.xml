<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".games.sudoku.SudokuActivity">

    <!-- Sudoku Board (GridLayout) -->
    <GridLayout
        android:id="@+id/sudoku_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:columnCount="9"
        android:rowCount="9"
        android:background="@drawable/sudoku_board_background"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/num_pad_label">
        <!-- Cells will be added dynamically in code -->
    </GridLayout>

    <TextView
        android:id="@+id/num_pad_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number Pad:"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sudoku_grid" />

    <!-- Number Input Pad (GridLayout for 1-9, LinearLayout for Clear/Controls) -->
    <GridLayout
        android:id="@+id/num_pad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="5"
        android:rowCount="2"
        android:layout_margin="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/num_pad_label"
        app:layout_constraintBottom_toTopOf="@id/btn_new_game">

        <TextView
            android:id="@+id/btn_1"
            style="@style/SudokuNumPadButton"
            android:text="1" />
        <TextView
            android:id="@+id/btn_2"
            style="@style/SudokuNumPadButton"
            android:text="2" />
        <TextView
            android:id="@+id/btn_3"
            style="@style/SudokuNumPadButton"
            android:text="3" />
        <TextView
            android:id="@+id/btn_4"
            style="@style/SudokuNumPadButton"
            android:text="4" />
        <TextView
            android:id="@+id/btn_5"
            style="@style/SudokuNumPadButton"
            android:text="5" />
        <TextView
            android:id="@+id/btn_6"
            style="@style/SudokuNumPadButton"
            android:text="6" />
        <TextView
            android:id="@+id/btn_7"
            style="@style/SudokuNumPadButton"
            android:text="7" />
        <TextView
            android:id="@+id/btn_8"
            style="@style/SudokuNumPadButton"
            android:text="8" />
        <TextView
            android:id="@+id/btn_9"
            style="@style/SudokuNumPadButton"
            android:text="9" />
        <TextView
            android:id="@+id/btn_clear"
            style="@style/SudokuNumPadButton"
            android:layout_columnSpan="2"
            android:text="Clear" />
    </GridLayout>

    <Button
        android:id="@+id/btn_new_game"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"
        android:text="New Game"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_solve"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_solve"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="Solve"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_new_game" />

</androidx.constraintlayout.widget.ConstraintLayout>
